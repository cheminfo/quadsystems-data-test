{
  "name": "quadsystems-data-test",
  "version": "1.0.0",
  "description": "Provides Quad Systems NMR data files for testing purposes",
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "keywords": [
    "magnetic resonance",
    "nmr",
    "quadsystems",
    "dataset"
  ],
  "files": [
    "src",
    "lib",
    "data"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "clean": "rimraf lib",
    "eslint": "eslint . --cache",
    "eslint-fix": "node --run eslint -- --fix",
    "prepack": "node --run tsc",
    "prettier": "prettier --check .",
    "prettier-write": "prettier --write .",
    "test": "node --run test-only && node --run eslint && node --run prettier && node --run check-types",
    "test-only": "vitest --run --coverage",
    "tsc": "node --run clean && node --run tsc-build",
    "tsc-build": "tsc --project tsconfig.build.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmrdata/quadsystems-data-test.git"
  },
  "bugs": {
    "url": "https://github.com/nmrdata/quadsystems-data-test/issues"
  },
  "homepage": "https://github.com/nmrdata/quadsystems-data-test#readme",
  "dependencies": {
    "data-test-api": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "@zakodium/tsconfig": "^1.0.3",
    "eslint": "^9.31.0",
    "eslint-config-cheminfo-typescript": "^21.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1"
  }
}
